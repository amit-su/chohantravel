function validateEmail($email) {
  var emailReg = /^([\w-\.]+@([\w-]+\.)+[\w-]{2,4})?$/;
  return emailReg.test( $email );
}
  $(document).ready(function(){

    $('#mobile').on('keydown',function(e){-1!==$.inArray(e.keyCode,[46,8,9,27,13,110,190])||/65|67|86|88/.test(e.keyCode)&&(!0===e.ctrlKey||!0===e.metaKey)||35<=e.keyCode&&40>=e.keyCode||(e.shiftKey||48>e.keyCode||57<e.keyCode)&&(96>e.keyCode||105<e.keyCode)&&e.preventDefault()});

  	  $('#submit').click(function(){
         var flag = 0;
         var name = $('#name').val();
         var email = $('#email').val();
         var mobile = $('#mobile').val();
         var bus_category = $('#bus_category').val();
         var messege = $('#message').val();

         if(name == "")
         {
         	$('#name').focus();
            swal("Oops!", "Enter your full name", "error");
            return;
         }
         else{
         	flag++;
         }

         if(email == "")
         {
         	$('#email').focus();
            swal("Oops!", "Enter your valid mail address", "error");
            return;
         }
         else{
         	flag++;
         }

         if(!validateEmail(email)) { 
         	$('#email').val("");
         	$('#email').focus();
            swal("Oops!", "Email address not valid", "error");
            return;
         }
         else{
         	flag++;
         }

         if(mobile.length < 10 || mobile.length > 10) { 
         	$('#mobile').val("");
         	$('#mobile').focus();
            swal("Oops!", "Enter 10 digit mobile number", "error");
            return;
         }
         else{
         	flag++;
         }


         if(bus_category == 0) { 
         	
            swal("Oops!", "Select type of bus you want to book", "error");
            return;
         }
         else{
         	flag++;
         }

         if(message == "") { 
         	
            swal("Oops!", "Enter your message in few lines", "error");
            return;
         }
         else{
         	flag++;
         }



         if(flag == 6)
         {
         	$('#frm').submit();

         }


  	  });
  });
</script>
