	<script src="<?php echo URL::to('/'); ?>/assets/admin/plugins/parsley/dist/parsley.js"></script>
	<script src="<?php echo URL::to('/'); ?>/assets/admin/js/apps.min.js"></script>
	<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
	<!-- ================== END PAGE LEVEL JS ================== -->
<script>
$(document).ready(function() {
   $('#update_settings').click(function(){
    var flag = 0;
        var contact_email = $('#contact_email').val();
        var contact_no = $('#contact_no').val();
        var footer_text = $('#footer_text').val();
        var facebook_link = $('#facebook_link').val();
        var twitter_link = $('#twitter_link').val();
        var linkedin_link = $('#linkedin_link').val();
        var google_plus_link = $('#google_plus_link').val();
        var youtube_link = $('#youtube_link').val();

        if(contact_email == "")
        {
          swal("Enter contact email", {
            buttons: false,
            timer: 3000,
            icon: "error"
          });
        }
        else{
            flag++;
        }

        if(contact_no == "")
        {
          swal("Enter contact no", {
            buttons: false,
            timer: 3000,
            icon: "error"
          });
        }
        else{
            flag++;
        }

        if(footer_text == "")
        {
          swal("Enter footer text", {
            buttons: false,
            timer: 3000,
            icon: "error"
          });
        }
        else{
            flag++;
        }

        if(flag == 3)
        {
          $.post(base_url+'/update-site-settings',
              {
                contact_email:contact_email,
                contact_no:contact_no,
                footer_text:footer_text,
                facebook_link:facebook_link,
                twitter_link:twitter_link,
                linkedin_link:linkedin_link,
                google_plus_link:google_plus_link,
                youtube_link:youtube_link
              },
              function(data){
                  if(data.status == 1)
                  {
                     swal("Settings page updated, and active in site", {
                          buttons: false,
                          timer: 3000,
                          icon: "success"
                        });
                  }
              });
        }
   });
});
</script>
