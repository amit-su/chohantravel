	<!-- ================== END PAGE LEVEL JS ================== -->
	<script>
        var base_url = "<?php echo URL::to('/'); ?>";
		$(document).ready(function() {
			App.init();

            $('#login_btn').click(function(){
                var email = $('#email').val();
                var password = $('#password').val();

                $.post(base_url+'/admin',{email:email,password:password},function(data){
                    if(data.status == 1)
                    {
                        window.location.href(base_url+'/admin/dashboard');
                    }
                    else{
                        swal("Invalid email/password combination", {
                          buttons: false,
                          timer: 3000,
                          icon: "error"
                        });
                    }
                });
            });
            
		});
	</script>
	
