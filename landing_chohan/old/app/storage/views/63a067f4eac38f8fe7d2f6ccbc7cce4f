<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
<script>
$(document).ready(function(){
	var base_url = "<?php echo URL::to('/'); ?>";
	$('.change_status').click(function(){
		var id = $(this).attr("data-b");
		swal({
			  title: "Are you sure?",
			  text: "You want to deactivate the category",
			  icon: "warning",
			  buttons: true,
			  dangerMode: true,
			})
			.then((willDelete) => {
			  if (willDelete) {
				 $.post(base_url+'/deactivate-gallery-category',{id:id},function(data){
					 if(data.status == 1)
					 {
						 swal("Category has been deactivated", {
						  icon4: "success", 
						});
						window.location.reload();
					 }
				 });
				
			  } 
			});
	});
	
	$('.delete').click(function(){
		var id = $(this).attr("data-b");
		swal({
			  title: "Are you sure you want to delete?",
			  text: "Deleting the category will delete the images also",
			  icon: "warning",
			  buttons: true,
			  dangerMode: true,
			})
			.then((willDelete) => {
			  if (willDelete) {
				 $.post(base_url+'/delete-gallery-category',{id:id},function(data){
					 if(data.status == 1)
					 {
						 swal("Category has been deleted, with all images", {
						  icon4: "success", 
						});
						window.location.reload();
					 }
				 });
				
			  } 
			});
	});
	
	$('#create_new_gallery_cat').click(function(){
		var category_name = $('#category_name').val();
		if(category_name == "")
		{
			swal("Oops", "Enter new gallery category name", "error");
			return;
		}
		else{
			$.post(base_url+'/add-new-category',{category_name:category_name},function(data){
				if(data.status == 1)
				{
					swal("Done","New gallery category added", "success");
					window.location.reload();
				}
			});
		}
	});
	
	$('.manage_images').click(function(){
		var id = $(this).attr("data-b");
		window.location.replace(base_url+'/admin/manage-images/'+id);
	});
});
</script>
</body>
</html>

